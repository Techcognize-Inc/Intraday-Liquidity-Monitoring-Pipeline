{
  "__inputs": [
    {
      "name": "DS_POSTGRESQL",
      "label": "PostgreSQL",
      "description": "Liquidity monitoring PostgreSQL datasource",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.4.0"
    },
    {
      "type": "datasource",
      "id": "postgres",
      "name": "PostgreSQL",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "gauge",
      "name": "Gauge",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "barchart",
      "name": "Bar chart",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "Intraday Liquidity Monitoring — Real-time treasury position dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Live Position Gauge — Available Liquidity by Account",
      "description": "Current available balance per settlement account. Green=above warning, Amber=below warning, Red=below critical.",
      "type": "gauge",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "minVizHeight": 75,
        "minVizWidth": 75
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 500000000
              },
              {
                "color": "green",
                "value": 2000000000
              }
            ]
          },
          "unit": "currencyGBP",
          "min": 0,
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "liquidity-postgres"
          },
          "rawSql": "SELECT settlement_account AS metric, available_balance AS value FROM liquidity_positions ORDER BY currency, settlement_account",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Intraday Timeline — Balance by Account (00:00 to Now)",
      "description": "Running balance over time. Threshold reference lines show WARNING and CRITICAL levels.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "fillOpacity": 10,
        "gradientMode": "opacity"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "drawStyle": "line",
            "spanNulls": false,
            "showPoints": "never"
          },
          "unit": "currencyGBP",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 500000000
              },
              {
                "color": "green",
                "value": 2000000000
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "liquidity-postgres"
          },
          "rawSql": "SELECT last_updated AS time, available_balance AS value, settlement_account AS metric FROM liquidity_positions WHERE last_updated >= NOW() - INTERVAL '8 hours' ORDER BY last_updated",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Net Flow by Currency — 5-Minute Windows",
      "description": "Net inbound/outbound per currency per 5-min tumbling window. Positive = net inflow, Negative = net outflow.",
      "type": "barchart",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "options": {
        "orientation": "auto",
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "fillOpacity": 80,
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "currencyGBP",
          "custom": {
            "fillOpacity": 80
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "liquidity-postgres"
          },
          "rawSql": "SELECT window_start AS time, net_flow AS value, currency AS metric FROM liquidity_flow_summary WHERE window_start >= NOW() - INTERVAL '2 hours' ORDER BY window_start, currency",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Pending Payments Queue — Next 2 Hours",
      "description": "Upcoming payment obligations. DEBIT = liquidity outflow. Sorted by expected settlement time.",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Settlement Time",
            "desc": false
          }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "direction"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "DEBIT": {
                        "color": "red",
                        "index": 0,
                        "text": "DEBIT"
                      }
                    },
                    "type": "value"
                  },
                  {
                    "options": {
                      "CREDIT": {
                        "color": "green",
                        "index": 1,
                        "text": "CREDIT"
                      }
                    },
                    "type": "value"
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "amount"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyGBP"
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "liquidity-postgres"
          },
          "rawSql": "SELECT expected_settlement_time AS \"Settlement Time\", currency, settlement_account AS \"Account\", amount, direction, rail AS \"Rail\", counterparty AS \"Counterparty\" FROM pending_payments WHERE status = 'PENDING' AND expected_settlement_time BETWEEN NOW() AND NOW() + INTERVAL '2 hours' ORDER BY expected_settlement_time ASC LIMIT 50",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Feed Health — Payment Rail Liveness",
      "description": "Green = live feed. Amber = stale (no events in 60s — FeedStaleAlert fired). Flink EventTimeTimer drives this.",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              }
            ]
          },
          "mappings": [
            {
              "options": {
                "false": {
                  "text": "LIVE",
                  "color": "green"
                },
                "true": {
                  "text": "STALE",
                  "color": "orange"
                }
              },
              "type": "value"
            }
          ]
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "liquidity-postgres"
          },
          "rawSql": "SELECT rail AS metric, CASE WHEN is_stale THEN 1 ELSE 0 END AS value FROM feed_health ORDER BY rail",
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": [
    "liquidity",
    "treasury",
    "intraday",
    "flink"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-8h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "utc",
  "title": "Intraday Liquidity Monitoring",
  "uid": "intraday-liquidity-v1",
  "version": 1,
  "weekStart": ""
}